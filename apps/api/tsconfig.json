{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "outDir": "./dist",
    "rootDir": "../../",
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "./**/*.ts",
    "../../packages/shared/schema/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}